generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id        String    @id @default(cuid())
  name      String
  nameEn    String
  slug      String    @unique
  icon      String?
  products  Product[]
  createdAt DateTime  @default(now())
}

model Product {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  description   String
  ingredients   String?
  howToUse      String?
  price         Float
  originalPrice Float?
  stock         Int      @default(0)
  sold          Int      @default(0)
  images        String[]
  badge         String?
  rating        Float    @default(4.5)
  reviewCount   Int      @default(0)
  size          String?
  isActive      Boolean  @default(true)
  categoryId    String
  category      Category @relation(fields: [categoryId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AdminUser {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
}
